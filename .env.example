# Server Configuration
PORT=3000

# Email Configuration
# The email address that will SEND the notifications
EMAIL_USER=your_email@gmail.com

# 16-character App Password (if using Gmail)
EMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# (Optional) The email address that will RECEIVE the notifications. 
# Defaults to EMAIL_USER if left blank.
EMAIL_RECEIVER=studio_owner@gmail.com
